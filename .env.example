VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# imgBB API Key per l'upload delle immagini
# Ottieni una key gratuita su https://api.imgbb.com/
VITE_IMGBB_API_KEY=your-imgbb-api-key

# Password di classe per l'accesso all'app
# Inserisci qui la password fornita dal professore
VITE_CLASS_PASSWORD=your-class-password

# Password admin per la dashboard segreta (/#/admin)
# Lascia vuoto per disabilitare l'accesso admin
VITE_ADMIN_PASSWORD=your-admin-password
